<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>Mtzhr</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>mtzhr</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<key>UIStatusBarHidden</key>
		<false/>
		
		<!-- Location Permissions -->
		<key>NSLocationWhenInUseUsageDescription</key>
		<string>نحتاج الوصول إلى موقعك لتسجيل الحضور والانصراف بدقة</string>
		<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
		<string>نحتاج الوصول إلى موقعك حتى عند عمل التطبيق في الخلفية لتتبع الحضور</string>
		<key>NSLocationAlwaysUsageDescription</key>
		<string>نحتاج الوصول إلى موقعك بشكل دائم لتتبع الحضور والانصراف</string>
		
		<!-- Biometric Authentication -->
		<key>NSFaceIDUsageDescription</key>
		<string>نحتاج استخدام Face ID أو Touch ID لتسجيل الدخول الآمن</string>
		
		<!-- Camera Permissions -->
		<key>NSCameraUsageDescription</key>
		<string>نحتاج الوصول إلى الكاميرا لالتقاط الصور الشخصية</string>
		
		<!-- Photo Library Permissions -->
		<key>NSPhotoLibraryUsageDescription</key>
		<string>نحتاج الوصول إلى الصور لاختيار الصور الشخصية</string>
		
		<!-- Microphone Permissions -->
		<key>NSMicrophoneUsageDescription</key>
		<string>نحتاج الوصول إلى الميكروفون للتسجيل الصوتي</string>
		
		<!-- Network Permissions -->
		<key>NSAppTransportSecurity</key>
		<dict>
			<key>NSAllowsArbitraryLoads</key>
			<true/>
			<key>NSExceptionDomains</key>
			<dict>
				<key>localhost</key>
				<dict>
					<key>NSExceptionAllowsInsecureHTTPLoads</key>
					<true/>
				</dict>
			</dict>
		</dict>
		
		<!-- Background Modes -->
		<key>UIBackgroundModes</key>
		<array>
			<string>location</string>
			<string>fetch</string>
			<string>processing</string>
		</array>
		
		<!-- Notification Permissions -->
		<key>UNUserNotificationCenter</key>
		<true/>
		
		<!-- Firebase Configuration -->
		<key>FirebaseAppDelegateProxyEnabled</key>
		<false/>
		
		<!-- Minimum iOS Version -->
		<key>MinimumOSVersion</key>
		<string>12.0</string>
		
		<!-- Device Orientation -->
		<key>UIRequiresFullScreen</key>
		<false/>
		
		<!-- Status Bar Configuration -->
		<key>UIViewControllerBasedStatusBarAppearance</key>
		<true/>
		
		<!-- Privacy Settings -->
		<key>NSUserTrackingUsageDescription</key>
		<string>قد نستخدم بياناتك لتحسين الخدمة وتخصيص المحتوى</string>
		
		<!-- App Store Connect -->
		<key>ITSAppUsesNonExemptEncryption</key>
		<false/>
	</dict>
</plist>
